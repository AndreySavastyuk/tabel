# Пример конфигурации Табель СКУД.
# Скопируйте в .env (он в .gitignore) и заполните под своё окружение.
# Все переменные читаются классом api.config.Settings (префикс TABEL_).
#
# Локально (dev) можно НИЧЕГО не задавать — рабочие дефолты подставятся сами.
# Для прода выставьте TABEL_ENV=prod: тогда приложение НЕ поднимется, пока не
# заданы безопасный секрет, явные CORS-origin'ы и не-SQLite БД (fail fast).

# --- Окружение -------------------------------------------------------------
# dev (по умолчанию) | prod. prod включает строгие проверки конфигурации.
# ВНИМАНИЕ: alembic/env.py импортирует Settings, поэтому в проде `alembic
# upgrade head` тоже требует весь prod-блок (секрет, CORS, не-SQLite БД).
TABEL_ENV=dev

# --- Безопасность / JWT ----------------------------------------------------
# ОБЯЗАТЕЛЬНО в проде: случайный секрет >= 32 символов. Сгенерировать:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
TABEL_SECRET_KEY=dev-secret-change-me-in-production
# Алгоритм подписи JWT (обычно не меняется).
TABEL_ALGORITHM=HS256
# Время жизни токенов (минуты). В проде рекомендуется укоротить access-токен
# (например 30–60) — он stateless и не отзывается до истечения.
TABEL_ACCESS_TOKEN_EXPIRE_MINUTES=720
TABEL_REFRESH_TOKEN_EXPIRE_MINUTES=20160
# Стоимость bcrypt для новых хэшей паролей (>=12; можно повышать со временем).
TABEL_BCRYPT_ROUNDS=12

# --- База данных -----------------------------------------------------------
# dev: SQLite-файл. В проде ОБЯЗАТЕЛЬНО PostgreSQL (SQLite будет отклонён):
#   TABEL_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/tabel
TABEL_DATABASE_URL=sqlite:///./tabel.db

# --- CORS ------------------------------------------------------------------
# dev: '*' (любой origin). В проде '*' ЗАПРЕЩЁН — перечислите явные origin'ы
# фронтенда через запятую, например:
#   TABEL_CORS_ORIGINS=https://tabel.example,https://www.tabel.example
TABEL_CORS_ORIGINS=*

# --- Рабочая директория (выгрузки/справочники) -----------------------------
# По умолчанию — корень проекта. В проде укажите путь вне дерева исходников.
# TABEL_WORKDIR=/var/lib/tabel
# Папка для загруженных файлов. dev: <workdir>/_uploads. В проде ОБЯЗАТЕЛЬНО
# абсолютный путь вне дерева исходников (иначе старт будет отклонён).
# TABEL_UPLOAD_DIR=/var/lib/tabel/uploads

# --- Начальный admin для прода (используется только при TABEL_ENV=prod) -----
# Сидер (scripts.seed_from_excel) в проде НЕ создаёт дев-юзеров admin/admin и
# заводит одного admin с этим паролем (>= 12 символов). В dev не используется.
# TABEL_BOOTSTRAP_ADMIN_PASSWORD=
